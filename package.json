{
  "name": "sqtools",
  "version": "1.0.0",
  "description": "Multi-tenant Square POS management platform — loyalty, inventory, expiry discounts, vendor management, delivery, and more.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "migrate": "node scripts/migrate.js"
  },
  "keywords": [
    "inventory",
    "square",
    "pos",
    "dashboard",
    "addon",
    "reorder",
    "analytics"
  ],
  "author": "SqTools",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.0",
    "express-validator": "^7.0.1",
    "googleapis": "^144.0.0",
    "helmet": "^7.1.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.5",
    "pg": "^8.17.1",
    "square": "^43.2.1",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
